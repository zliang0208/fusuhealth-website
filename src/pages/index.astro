---
import Layout from '../layouts/Layout.astro';
---

<Layout title="首页" description="扶苏健康科技 — 面向麻醉科医生的 AI 知识服务平台。AI文献检索、医学生图、课题撰写，覆盖学、教、研、写全场景。">

<style>
  /* Hero */
  .hero {
    background: linear-gradient(160deg, #0f1e35 0%, #1a3560 60%, #0f2a50 100%);
    color: #fff;
    padding: 90px 0 80px;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 60% 50% at 70% 50%, rgba(6,182,212,.12) 0%, transparent 70%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(6,182,212,.15);
    border: 1px solid rgba(6,182,212,.3);
    color: #67e8f9;
    font-size: .8rem;
    font-weight: 600;
    padding: 5px 14px;
    border-radius: 20px;
    margin-bottom: 20px;
    letter-spacing: .04em;
  }
  .hero h1 {
    font-size: 2.6rem;
    font-weight: 900;
    line-height: 1.2;
    margin-bottom: 20px;
    letter-spacing: -.5px;
  }
  .hero h1 span { color: #38bdf8; }
  .hero-desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,.75);
    line-height: 1.8;
    margin-bottom: 32px;
    max-width: 460px;
  }
  .hero-btns { display: flex; gap: 14px; flex-wrap: wrap; }
  .btn-primary {
    background: #2563eb;
    color: #fff;
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: .95rem;
    transition: background .2s, transform .15s;
    display: inline-block;
  }
  .btn-primary:hover { background: #1d4ed8; transform: translateY(-1px); color: #fff; }
  .btn-ghost {
    color: rgba(255,255,255,.85);
    border: 1px solid rgba(255,255,255,.25);
    padding: 12px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: .95rem;
    transition: all .2s;
    display: inline-block;
  }
  .btn-ghost:hover { background: rgba(255,255,255,.08); color: #fff; }

  /* Hero visual */
  .hero-visual {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .mock-card {
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 10px;
    padding: 16px 20px;
    backdrop-filter: blur(8px);
  }
  .mock-card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
  }
  .mock-icon {
    width: 32px; height: 32px;
    background: linear-gradient(135deg, #2563eb, #06b6d4);
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem; flex-shrink: 0;
  }
  .mock-title { font-size: .85rem; font-weight: 600; color: #e2e8f0; }
  .mock-sub { font-size: .78rem; color: rgba(255,255,255,.45); }
  .mock-body { font-size: .82rem; color: rgba(255,255,255,.6); line-height: 1.6; }
  .mock-highlight { color: #38bdf8; }

  /* Stats bar */
  .stats-bar {
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
    padding: 24px 0;
  }
  .stats-inner {
    display: flex;
    justify-content: space-around;
    flex-wrap: wrap;
    gap: 20px;
    text-align: center;
  }
  .stat-num {
    font-size: 1.8rem;
    font-weight: 900;
    color: var(--primary);
    line-height: 1;
  }
  .stat-label { font-size: .82rem; color: var(--muted); margin-top: 4px; }

  /* Who */
  .who-section { padding: 72px 0; }
  .scenario-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    margin-top: 40px;
  }
  .scenario-card {
    background: var(--bg-soft);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 20px;
    text-align: center;
    transition: border-color .2s, box-shadow .2s;
  }
  .scenario-card:hover { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(37,99,235,.08); }
  .scenario-icon { font-size: 2rem; margin-bottom: 12px; }
  .scenario-word { font-size: 1.4rem; font-weight: 900; color: var(--primary); margin-bottom: 6px; }
  .scenario-name { font-size: .9rem; font-weight: 600; margin-bottom: 6px; }
  .scenario-desc { font-size: .82rem; color: var(--muted); line-height: 1.6; }

  /* Products */
  .products-section { padding: 72px 0; background: var(--bg-soft); }
  .products-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    margin-top: 48px;
  }
  .product-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 32px;
    box-shadow: var(--shadow);
    transition: box-shadow .2s, transform .2s;
  }
  .product-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,.1); transform: translateY(-2px); }
  .product-card.featured { border-color: var(--primary); box-shadow: 0 0 0 1px var(--primary), var(--shadow); }
  .product-header { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 16px; }
  .product-icon {
    width: 48px; height: 48px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.4rem;
    flex-shrink: 0;
  }
  .icon-blue  { background: #dbeafe; }
  .icon-cyan  { background: #cffafe; }
  .icon-purple{ background: #ede9fe; }
  .icon-green { background: #dcfce7; }
  .product-name { font-size: 1.15rem; font-weight: 700; margin-bottom: 8px; }
  .product-desc { color: var(--muted); font-size: .9rem; line-height: 1.7; margin-bottom: 18px; }
  .product-features { list-style: none; }
  .product-features li {
    font-size: .875rem;
    color: var(--text);
    padding: 5px 0;
    border-top: 1px solid var(--border);
    display: flex; align-items: flex-start; gap: 8px;
  }
  .product-features li::before { content: '✓'; color: #16a34a; font-weight: 700; flex-shrink: 0; margin-top: 1px; }

  /* WeChat CTA */
  .wechat-section { padding: 72px 0; }
  .wechat-card {
    background: linear-gradient(135deg, #0f1e35, #1a3560);
    border-radius: 16px;
    padding: 56px 48px;
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 40px;
    align-items: center;
    color: #fff;
  }
  .wechat-card h2 { font-size: 1.7rem; font-weight: 800; margin-bottom: 12px; }
  .wechat-card p { color: rgba(255,255,255,.7); font-size: .95rem; line-height: 1.7; }
  .wechat-box {
    background: rgba(255,255,255,.07);
    border: 1px solid rgba(255,255,255,.15);
    border-radius: 12px;
    padding: 24px 32px;
    text-align: center;
    flex-shrink: 0;
  }
  .wechat-box .wx-icon { font-size: 2rem; margin-bottom: 8px; }
  .wechat-box .wx-name { font-size: .9rem; font-weight: 700; color: #67e8f9; margin-bottom: 4px; }
  .wechat-box .wx-hint { font-size: .78rem; color: rgba(255,255,255,.5); }

  @media (max-width: 900px) {
    .hero-inner { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .scenario-grid { grid-template-columns: repeat(2, 1fr); }
    .products-grid { grid-template-columns: 1fr; }
    .wechat-card { grid-template-columns: 1fr; }
    .hero h1 { font-size: 2rem; }
  }
</style>

<!-- Hero -->
<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div>
        <div class="hero-eyebrow">
          <span>⚡</span> AI 驱动 · 专注麻醉学
        </div>
        <h1>让麻醉科医生<br/>从<span>文献堆</span>中解放</h1>
        <p class="hero-desc">
          扶苏健康科技专注麻醉学领域，用 AI 技术覆盖医生的「学、教、研、写」四大场景——
          从文献检索到课题撰写，把原本耗时数小时的工作压缩到分钟级。
        </p>
        <div class="hero-btns">
          <a href="/services" class="btn-primary">查看全部服务 →</a>
          <a href="/about" class="btn-ghost">了解我们</a>
        </div>
      </div>
      <div class="hero-visual">
        <div class="mock-card">
          <div class="mock-card-header">
            <div class="mock-icon">🔍</div>
            <div>
              <div class="mock-title">AI 文献检索</div>
              <div class="mock-sub">搜索：围术期低血压管理</div>
            </div>
          </div>
          <div class="mock-body">找到 <span class="mock-highlight">847 篇</span>相关文献 · 已筛选近5年高影响力论文 <span class="mock-highlight">23 篇</span></div>
        </div>
        <div class="mock-card">
          <div class="mock-card-header">
            <div class="mock-icon">📄</div>
            <div>
              <div class="mock-title">Anesthesiology 2024</div>
              <div class="mock-sub">IF 9.1 · PMID 38241839</div>
            </div>
          </div>
          <div class="mock-body">
            <span class="mock-highlight">AI 摘要：</span>该 RCT 纳入 2847 例患者，目标导向液体治疗组术后器官并发症发生率降低 <span class="mock-highlight">31%</span>（P&lt;0.001）...
          </div>
        </div>
        <div class="mock-card">
          <div class="mock-card-header">
            <div class="mock-icon">📝</div>
            <div>
              <div class="mock-title">PPT 要点已生成</div>
              <div class="mock-sub">基于 23 篇文献综合分析</div>
            </div>
          </div>
          <div class="mock-body">核心数据 · 指南推荐 · 参考文献列表 <span class="mock-highlight">已就绪</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Stats bar -->
<section class="stats-bar">
  <div class="container">
    <div class="stats-inner">
      <div>
        <div class="stat-num">3,000万+</div>
        <div class="stat-label">PubMed 可检索文献量</div>
      </div>
      <div>
        <div class="stat-num">5–15分钟</div>
        <div class="stat-label">完成一次完整文献检索</div>
      </div>
      <div>
        <div class="stat-num">4 大产品</div>
        <div class="stat-label">覆盖学·教·研·写</div>
      </div>
      <div>
        <div class="stat-num">100% 专注</div>
        <div class="stat-label">麻醉学垂直领域</div>
      </div>
    </div>
  </div>
</section>

<!-- Who is this for -->
<section class="who-section">
