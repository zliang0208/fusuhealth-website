    <div class="scenario-grid">
      <div class="scenario-card">
        <div class="scenario-icon">📖</div>
        <div class="scenario-word">学</div>
        <div class="scenario-name">追踪学科前沿</div>
        <div class="scenario-desc">每周精选顶刊最新研究，AI 解读临床意义，碎片化时间高效学习</div>
      </div>
      <div class="scenario-card">
        <div class="scenario-icon">🎓</div>
        <div class="scenario-word">教</div>
        <div class="scenario-name">备课讲座准备</div>
        <div class="scenario-desc">输入主题，自动检索文献、提取数据要点，PPT 内容一键生成</div>
      </div>
      <div class="scenario-card">
        <div class="scenario-icon">🔬</div>
        <div class="scenario-word">研</div>
        <div class="scenario-name">科研课题设计</div>
        <div class="scenario-desc">AI 辅助文献综述、研究假设、课题标书全流程智能化撰写</div>
      </div>
      <div class="scenario-card">
        <div class="scenario-icon">✍️</div>
        <div class="scenario-word">写</div>
        <div class="scenario-name">论文与标书写作</div>
        <div class="scenario-desc">参考文献整理、方法学评价、中英文摘要生成，降低写作门槛</div>
      </div>
    </div>
  </div>
</section>

<!-- Products -->
