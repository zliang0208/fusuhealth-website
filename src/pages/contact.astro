---
import Layout from '../layouts/Layout.astro';
---

<Layout title="联系我们">
  <section style="padding: 60px 0;">
    <div class="container" style="max-width: 700px;">
      <h1 style="font-size: 2rem; margin-bottom: 24px;">联系我们</h1>

      <div style="border: 1px solid var(--border); border-radius: 12px; padding: 32px; margin-bottom: 24px;">
        <h2 style="font-size: 1.2rem; margin-bottom: 16px;">📧 邮件联系</h2>
        <p style="color: var(--text-secondary);">
          商务合作 / 服务咨询：<a href="mailto:admin@fusuhealth.net">admin@fusuhealth.net</a>
        </p>
      </div>

      <div style="border: 1px solid var(--border); border-radius: 12px; padding: 32px; margin-bottom: 24px;">
        <h2 style="font-size: 1.2rem; margin-bottom: 16px;">📱 微信公众号</h2>
        <p style="color: var(--text-secondary);">
          搜索关注「<strong>麻醉学文献解读</strong>」，获取最新文献解读和服务动态。
        </p>
      </div>

      <div style="border: 1px solid var(--border); border-radius: 12px; padding: 32px;">
        <h2 style="font-size: 1.2rem; margin-bottom: 16px;">🏢 公司信息</h2>
        <p style="color: var(--text-secondary);">
          公司名称：杭州扶苏健康科技有限公司<br />
          官方网站：fusuhealth.cn
        </p>
      </div>
    </div>
  </section>
</Layout>
