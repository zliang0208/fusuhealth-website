---
interface Props {
  title: string;
  description?: string;
}

const { title, description = '杭州扶苏健康科技有限公司 — AI驱动的麻醉学知识服务平台' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | 扶苏健康科技</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --primary: #1a73e8;
      --primary-dark: #1557b0;
      --bg: #ffffff;
      --bg-light: #f8f9fa;
      --text: #202124;
      --text-secondary: #5f6368;
      --border: #e8eaed;
      --max-width: 1100px;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Microsoft YaHei", sans-serif;
      color: var(--text);
      line-height: 1.7;
      background: var(--bg);
    }

    a { color: var(--primary); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .container { max-width: var(--max-width); margin: 0 auto; padding: 0 24px; }
  </style>
</head>
<body>
  <header style="border-bottom: 1px solid var(--border); padding: 16px 0;">
    <div class="container" style="display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
      <a href="/" style="font-size: 1.25rem; font-weight: 700; color: var(--text);">
        🏥 扶苏健康科技
      </a>
      <nav style="display: flex; gap: 24px; font-size: 0.95rem;">
        <a href="/">首页</a>
        <a href="/about">关于我们</a>
        <a href="/services">服务</a>
        <a href="/contact">联系我们</a>
      </nav>
    </div>
  </header>

  <main>
    <slot />
  </main>

  <footer style="background: var(--bg-light); border-top: 1px solid var(--border); padding: 40px 0; margin-top: 60px;">
    <div class="container" style="text-align: center; color: var(--text-secondary); font-size: 0.875rem;">
      <p>© 2025 杭州扶苏健康科技有限公司</p>
      <p style="margin-top: 8px;">联系邮箱：admin@fusuhealth.net</p>
    </div>
  </footer>
</body>
</html>
